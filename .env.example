# 阿里云 DashScope API Key (通义千问、通义万象)
DASHSCOPE_API_KEY=your_dashscope_api_key

# 可灵AI API Key (视频生成)
KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key

# LangSmith 追踪配置 (可选)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key
LANGCHAIN_PROJECT=product-visual-generator

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 存储配置
STORAGE_TYPE=local
STORAGE_PATH=./output

# 日志配置
LOG_LEVEL=INFO