# ===== LLM 配置 =====
# LLM 提供商: qwen (百炼 OpenAI 兼容) 或 dashscope (DashScope SDK)
LLM_PROVIDER=qwen

# 千问百炼 API Key (OpenAI 兼容模式 + DashScope 共用同一 Key)
QWEN_API_KEY=your_qwen_api_key
QWEN_API_BASE=https://your-bailian-endpoint/compatible-mode/v1
QWEN_LLM_MODEL=qwen-plus

# DashScope API Key (与 QWEN_API_KEY 可共用)
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_API_BASE=https://your-bailian-endpoint/api/v1

# 可灵AI API Key (视频生成)
KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key

# ===== LangSmith 追踪配置 (可选) =====
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key
LANGCHAIN_PROJECT=agent-part

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ===== 存储配置 =====
STORAGE_TYPE=local
STORAGE_PATH=./output

# ===== 日志配置 =====
LOG_LEVEL=INFO

# ===== PostgreSQL 配置 =====
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/agent_part

# ===== Redis 配置 =====
REDIS_URL=redis://localhost:6379/0

# ===== RAG 配置 =====
RAG_ENABLED=true
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=BAAI/bge-large-zh
EMBEDDING_DEVICE=cpu
VECTOR_DIMENSION=1024
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.5

# ===== Mock 资产降级 =====
ALLOW_MOCK_ASSETS=true
